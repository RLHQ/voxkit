{
  "transcription": [
    {
      "timestamps": {"from": "00:00:00,000", "to": "00:00:02,500"},
      "offsets": {"from": 0, "to": 2500},
      "text": "大家好,我是猫宫柚。"
    },
    {
      "timestamps": {"from": "00:00:02,500", "to": "00:00:05,000"},
      "offsets": {"from": 2500, "to": 5000},
      "text": "今天我们来聊聊语音识别。"
    },
    {
      "timestamps": {"from": "00:00:05,000", "to": "00:00:07,800"},
      "offsets": {"from": 5000, "to": 7800},
      "text": "首先要解决的是断句问题。"
    },
    {
      "timestamps": {"from": "00:00:07,800", "to": "00:00:10,200"},
      "offsets": {"from": 7800, "to": 10200},
      "text": "中文不像英文有空格分词。"
    },
    {
      "timestamps": {"from": "00:00:10,200", "to": "00:00:12,400"},
      "offsets": {"from": 10200, "to": 12400},
      "text": "所以我们采用短语级分段。"
    },
    {
      "timestamps": {"from": "00:00:12,400", "to": "00:00:14,600"},
      "offsets": {"from": 12400, "to": 14600},
      "text": "每个短语对应一个段落。"
    },
    {
      "timestamps": {"from": "00:00:14,600", "to": "00:00:17,200"},
      "offsets": {"from": 14600, "to": 17200},
      "text": "这样下游字幕就能直接使用。"
    },
    {
      "timestamps": {"from": "00:00:17,200", "to": "00:00:19,800"},
      "offsets": {"from": 17200, "to": 19800},
      "text": "希望今天的分享对大家有帮助。"
    },
    {
      "timestamps": {"from": "00:00:19,800", "to": "00:00:22,000"},
      "offsets": {"from": 19800, "to": 22000},
      "text": "感谢你的观看,我们下期再见。"
    }
  ]
}
